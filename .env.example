# IntelliForm Environment Variables
# Copy this file to .env and fill in your values

# LLM — get free key at console.groq.com
GROQ_API_KEY=

# Optional: run a local Ollama model instead of Groq
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# PostHog analytics (optional — app works without it)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Supabase persistence (optional — falls back to in-memory)
SUPABASE_URL=
SUPABASE_ANON_KEY=
